{
  "db_name": "PostgreSQL",
  "query": "\n            UPDATE jobs\n            SET status = 'pending', retries = retries + 1\n            WHERE id IN (\n                SELECT id FROM jobs\n                WHERE status = 'failed'\n                AND retries < max_retries\n                FOR UPDATE SKIP LOCKED\n                LIMIT $1\n            )\n            RETURNING id, \"type\", payload, status AS \"status: JobStatus\", retries, max_retries, job_definition_id, created_at;",
