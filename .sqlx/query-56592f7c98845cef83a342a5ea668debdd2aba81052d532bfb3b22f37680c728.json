  "query": "\n            UPDATE jobs\n            SET status = 'running'\n            WHERE id IN (\n              SELECT id FROM jobs\n              WHERE status = 'pending'\n              FOR UPDATE SKIP LOCKED\n              LIMIT $1\n            ) RETURNING id, \"type\", payload, status AS \"status: JobStatus\", retries, job_definition_id, created_at",
